{
  "expo": {
    "name": "Student App",
    "slug": "student-app",
    "version": "1.0.0",
    "scheme": "studentapp",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "runtimeVersion": {
      "policy": "appVersion"
    },


    "privacyUrl": "https://your-college.com/privacy-policy",
    "termsUrl": "https://your-college.com/terms",

    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#ffffff"
    },


    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.novaa.studentapp",
      "buildNumber": "1",
      "deploymentTarget": "13.0",


      "infoPlist": {

        "ITSAppUsesNonExemptEncryption": false,


        "NSCameraUsageDescription": "We need access to your camera to capture profile pictures.",
        "NSPhotoLibraryUsageDescription": "We need access to your photos to upload profile pictures and documents.",
        "NSPhotoLibraryAddOnlyUsageDescription": "We need permission to save photos from the app.",
        "NSLocationWhenInUseUsageDescription": "We need your location to track campus-based attendance.",
        "NSMicrophoneUsageDescription": "We need microphone access for video calls and recording.",


        "NSAllowsArbitraryLoads": false,
        "NSAllowsArbitraryLoadsInMedia": false,
        "NSExceptionDomains": {
          "your-college-api.com": {
            "NSIncludesSubdomains": true,
            "NSExceptionAllowsInsecureHTTPLoads": false,
            "NSExceptionMinimumTLSVersion": "TLSv1.2"
          }
        }
      },


      "entitlements": {
        "keychain-access-groups": ["group.com.novaa.studentapp"],
        "com.apple.developer.associated-domains": [
          "applinks:your-college.com"
        ]
      }
    },


    "android": {
      "package": "com.novaa.studentapp",
      "versionCode": 1,
      "minSdkVersion": 23,
      "targetSdkVersion": 34,
      "compileSdkVersion": 34,

      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#ffffff"
      },

      "edgeToEdgeEnabled": true,


      "permissions": [
        "android.permission.INTERNET",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.ACCESS_FINE_LOCATION",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.POST_NOTIFICATIONS"
      ],


      "networkSecurityConfig": "android_network_security_config"
    },


    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },


    "plugins": [
      [
        "expo-image-picker",
        {
          "cameraPermission": "Allow $(PRODUCT_NAME) to access your camera",
          "photosPermission": "Allow $(PRODUCT_NAME) to access your photos"
        }
      ],
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow $(PRODUCT_NAME) to use your location"
        }
      ],
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#ffffff"
        }
      ],
      [
        "expo-secure-store",
        {
          "faceIDPermission": "Allow $(PRODUCT_NAME) to use Face ID for authentication"
        }
      ]
    ],


    "updates": {
      "enabled": true,
      "checkAutomatically": "ON_LOAD",
      "fallbackToCacheTimeout": 30000,
      "url": "https://u.expo.dev/your-project-id"
    },


    "projectId": "09524a52-2784-4a03-80cc-c4fbc955a66e",


    "extra": {
      "eas": {
        "projectId": "09524a52-2784-4a03-80cc-c4fbc955a66e"
      },
      "apiUrl": "https://your-college-api.com",
      "appName": "Student App",
      "supportEmail": "support@your-college.com",
      "privacyPolicyUrl": "https://your-college.com/privacy-policy",
      "termsUrl": "https://your-college.com/terms"
    }
  }
}